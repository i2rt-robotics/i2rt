#!/usr/bin/env bash
#
# Convenience launcher for the workstation-side tools (recorder / replay / bridge).
#
# Activates the workstation uv venv and runs a tool, forwarding args. No ROS.
#
#   workstation/yam-data record [args]   # GUI recorder (teleop-gated LeRobot capture)
#   workstation/yam-data replay [args]   # GUI replay (drive the robot from a dataset)
#   workstation/yam-data bridge [args]   # policy bridge (portal robot <-> websocket policy)
#   workstation/yam-data cams            # list connected RealSense serials
#
# Override the venv with:  LEROBOT_ENV=~/yam_ws  workstation/yam-data record ...
#
# Examples:
#   workstation/yam-data record --robot-host 192.168.1.10 --serials A,B,C
#   workstation/yam-data bridge --robot-host 192.168.1.10 --policy-host 192.168.1.20
#   workstation/yam-data record --mock          # no hardware/robot/lerobot
set -eo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO"

ENV_PATH="${LEROBOT_ENV:-$HOME/yam_ws}"
# shellcheck disable=SC1091
[ -f "$ENV_PATH/bin/activate" ] && source "$ENV_PATH/bin/activate"

cmd="${1:-}"
shift || true
case "$cmd" in
    record) exec python -m workstation.lerobot_recorder "$@" ;;
    replay) exec python -m workstation.lerobot_recorder.replay_main "$@" ;;
    bridge) exec python -m workstation.policy_bridge "$@" ;;
    cams)   exec python -m workstation.lerobot_recorder.cameras --list ;;
    *)
        echo "usage: yam-data {record|replay|bridge|cams} [args]" >&2
        exit 2
        ;;
esac
