#!/usr/bin/env bash
#
# Convenience launcher for the i2rt robot server (runs on the ROBOT machine).
#
# Activates the robot uv venv (default: <repo>/.venv) and starts the portal robot
# server in the requested mode, forwarding any extra args. No ROS.
#
#   scripts/yam teleop  [args]   # auto home/engage bimanual teleop
#   scripts/yam dagger  [args]   # HG-DAgger: policy drives, button takeover
#   scripts/yam wrapper [args]   # followers track an external command (replay target)
#   scripts/yam can              # interactive persistent CAN-id setup
#   scripts/yam canup            # reset/bring up CAN interfaces at 1 Mbit/s
#
# Examples:
#   scripts/yam teleop --sim
#   scripts/yam teleop --bilateral-kp 0.15 --home 0,0,0,0,0,0
#   scripts/yam dagger --mirror-kp 0.2 --feedback-kp 0.1
#
# Override the venv with:  I2RT_VENV=/path/to/venv scripts/yam teleop ...
set -eo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"

VENV="${I2RT_VENV:-$REPO/.venv}"
if [ -f "$VENV/bin/activate" ]; then
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
fi

cmd="${1:-}"
shift || true
case "$cmd" in
    teleop)  exec python -m i2rt.serving.run_robot_server teleop  "$@" ;;
    dagger)  exec python -m i2rt.serving.run_robot_server dagger  "$@" ;;
    wrapper) exec python -m i2rt.serving.run_robot_server wrapper "$@" ;;
    can)     exec sh "$REPO/scripts/setup_can_ids.sh" "$@" ;;
    canup)   exec sh "$REPO/scripts/reset_all_can.sh" "$@" ;;
    *)
        echo "usage: yam {teleop|dagger|wrapper|can|canup} [args]" >&2
        exit 2
        ;;
esac
